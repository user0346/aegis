{
  "manifest_version": 3,
  "name": "AEGIS Guard",
  "short_name": "AEGIS",
  "version": "2.4.0",
  "description": "Schützt deinen Browser vor IP-Loggern, Phishing-URLs und verdächtigen Downloads. Komplementär zur AEGIS-Desktop-App.",
  "key": "",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "AEGIS Guard",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": [
    "storage",
    "webNavigation",
    "downloads",
    "notifications",
    "declarativeNetRequest",
    "scripting",
    "nativeMessaging",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "aegis_blocklist",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "web_accessible_resources": [
    {
      "resources": [
        "warn.html",
        "warn.css"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}